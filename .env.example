# Server
PORT=5001
NODE_ENV=development

# MongoDB (required)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/greenunimind

# JWT (required for auth)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRE=30d

# Gemini AI (required for AI features)
GEMINI_API_KEY=your_gemini_api_key

# Frontend URL (for CORS and email links — comma-separated for multiple origins)
CLIENT_URL=http://localhost:8080

# Rate Limiting (all values optional — sensible defaults are used)
# RATE_LIMIT_WINDOW_MS=900000          # Global API: window in ms (default: 15 min)
# RATE_LIMIT_MAX=200                   # Global API: max requests per window
# AUTH_RATE_LIMIT_WINDOW_MS=900000     # Auth endpoints: window in ms (default: 15 min)
# AUTH_RATE_LIMIT_MAX=15               # Auth endpoints: max attempts per window
# AI_RATE_LIMIT_WINDOW_MS=60000        # AI endpoints: window in ms (default: 1 min)
# AI_RATE_LIMIT_MAX=20                 # AI endpoints: max requests per window
# PAYMENT_RATE_LIMIT_WINDOW_MS=900000  # Payment endpoints: window in ms (default: 15 min)
# PAYMENT_RATE_LIMIT_MAX=30            # Payment endpoints: max requests per window
# UPLOAD_RATE_LIMIT_WINDOW_MS=900000   # Upload endpoints: window in ms (default: 15 min)
# UPLOAD_RATE_LIMIT_MAX=30             # Upload endpoints: max requests per window

# Stripe (optional - works in dev mode without these)
# STRIPE_SECRET_KEY=sk_test_your_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Email (optional - logs to console when not configured)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password
# EMAIL_FROM="GreenUniMind" <noreply@greenunimind.com>
