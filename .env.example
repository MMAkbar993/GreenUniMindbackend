# Server
PORT=5001
NODE_ENV=development

# MongoDB (required)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/greenunimind

# JWT (required for auth)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRE=30d

# Gemini AI (required for AI features)
GEMINI_API_KEY=your_gemini_api_key

# Frontend URL (for CORS and email links)
CLIENT_URL=http://localhost:8080

# Stripe (optional - works in dev mode without these)
# STRIPE_SECRET_KEY=sk_test_your_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Email (optional - logs to console when not configured)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password
# EMAIL_FROM="GreenUniMind" <noreply@greenunimind.com>
